{
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "gvn-framework-super-secret-key-min-32-chars!",
    "Issuer": "GvnFramework",
    "Audience": "GvnFramework.Clients",
    "ExpiryMinutes": 60
  },
  "Cache": {
    "UseRedis": false,
    "DefaultExpiryMinutes": 30,
    "Prefix": "gvn:"
  },
  "Hangfire": {
    "UseInMemory": true,
    "EnableDashboard": true,
    "WorkerCount": 3
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
